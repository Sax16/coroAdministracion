# ============================================================
# Plantilla de variables de entorno — copiar a .env y completar
# ============================================================
#
# Uso:
# cp .env.example .env
# # editar .env con tus credenciales reales del proyecto DEV
#
# ⚠️ .env está en .gitignore. Este .env.example SÍ se commitea
# (no contiene secretos, solo placeholders).
#
# ----- Entornos (dev / staging / prod) -----
# Este .env es solo para DESARROLLO LOCAL (`expo start`), que lee las
# variables de acá. Los builds de EAS NO leen este .env (no se commitea):
# toman las variables del bloque `env` de cada perfil en `eas.json`.
#   - development → proyecto Supabase dev
#   - preview     → proyecto Supabase staging
#   - production  → proyecto Supabase prod
# Completá los placeholders `REEMPLAZAR_CON_...` de eas.json con las
# publishable keys de cada proyecto cuando existan. Ver docs/02 §7.

# ----- Cliente (expuestas al bundle vía EXPO_PUBLIC_) -----
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_... (Publishable key de Project Settings → API)

# ----- Server-side / migrations / scripts (NO usar en cliente) -----
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... (Secret key de Project Settings → API)
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
