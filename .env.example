# ============================================================
# Plantilla de variables de entorno — copiar a .env y completar
# ============================================================
#
# Uso:
# cp .env.example .env
# # editar .env con tus credenciales reales
#
# ⚠️ .env está en .gitignore. Este .env.example SÍ se commitea
# (no contiene secretos, solo placeholders).

# ----- Cliente (expuestas al bundle vía EXPO_PUBLIC_) -----
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_... (Publishable key de Project Settings → API)

# ----- Server-side / migrations / scripts (NO usar en cliente) -----
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... (Secret key de Project Settings → API)
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
